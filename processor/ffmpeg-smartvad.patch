diff --git a/configure b/configure
index 26f8efe..a0e3773 100755
--- a/configure
+++ b/configure
@@ -2047,6 +2047,7 @@ EXTERNAL_LIBRARY_LIST="
     libdc1394
     libflite
     libfontconfig
+    libfvad
     libfreetype
     libfribidi
     libharfbuzz
@@ -4085,6 +4086,7 @@ amf_capture_filter_deps="amf"
 ametadata_filter_deps="avformat"
