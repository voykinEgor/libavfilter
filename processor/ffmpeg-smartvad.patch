 avgblur_opencl_filter_deps="opencl"
@@ -7261,6 +7263,7 @@ enabled libdvdread        && require_pkg_config libdvdread "dvdread >= 6.1.1"
 enabled libfdk_aac        && { check_pkg_config libfdk_aac fdk-aac "fdk-aac/aacenc_lib.h" aacEncOpen ||
                                check_pkg_config libfdk_aac "fdk-aac >= 0.1.3" "fdk-aac/aacenc_lib.h" aacEncOpen ||
                                die "ERROR: libfdk_aac not found"; }
